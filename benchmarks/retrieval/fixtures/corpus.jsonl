# WS16 synthetic retrieval fixture corpus (v1). Committed + versioned: any edit invalidates the baseline.
{"id":"auth-token","type":"code","name":"issueSessionToken","text":"export function issueSessionToken(userId: string): string {\n  // issue a signed session token for the authenticated user\n  return signJwt({ sub: userId, kind: 'session' });\n}"}
{"id":"auth-refresh","type":"code","name":"refreshSessionToken","text":"export function refreshSessionToken(oldToken: string): string {\n  // rotate the session token before expiry\n  const claims = verifyJwt(oldToken);\n  return signJwt({ ...claims, iat: now() });\n}"}
{"id":"retry-backoff","type":"code","name":"computeBackoffDelay","text":"export function computeBackoffDelay(attempt: number): number {\n  // exponential backoff with positive-only jitter for provider retries\n  return Math.min(30_000, 2 ** attempt * 250 + jitter());\n}"}
{"id":"ws-reconnect","type":"code","name":"scheduleReconnect","text":"export function scheduleReconnect(socketState: SocketState): void {\n  // websocket reconnect scheduling after a link drop\n  timerQueue.push(socketState.nodeId, computeBackoffDelay(socketState.attempt));\n}"}
{"id":"queue-drain","type":"code","name":"drainMessageQueue","text":"export function drainMessageQueue(queue: Message[]): void {\n  // flush buffered messages in order once the socket is open again\n  while (queue.length > 0) send(queue.shift()!);\n}"}
{"id":"csv-export","type":"code","name":"exportUsageCsv","text":"export function exportUsageCsv(rows: UsageRow[]): string {\n  // serialize usage metering rows to a CSV report\n  return rows.map((r) => `${r.day},${r.tokens}`).join('\\n');\n}"}
{"id":"sanitize-html","type":"code","name":"sanitizeHtml","text":"export function sanitizeHtml(input: string): string {\n  // strip script tags and event handlers from untrusted html\n  return input.replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, '');\n}"}
{"id":"parse-ndjson","type":"code","name":"parseNdjsonLine","text":"export function parseNdjsonLine(line: string): unknown {\n  // parse a newline-delimited json event line, tolerating trailing garbage\n  return JSON.parse(line.trim());\n}"}
{"id":"lesson-lock-order","type":"lesson","reinforcements":5,"text":"Always acquire the session mutex before writing provider identity; lock holders must use the *Locked variants or they self-deadlock."}
{"id":"lesson-quiet-tests","type":"lesson","reinforcements":4,"text":"Run the quiet test runner for full suites; default reporters dump thousands of lines and force context compaction."}
{"id":"lesson-verify-wiring","type":"lesson","reinforcements":3,"text":"Finding a class or flag proves it exists, not that it runs; trace definition to call site to wiring before claiming behavior."}
{"id":"lesson-grep-negatives","type":"lesson","reinforcements":2,"text":"macOS grep treats \\| literally; alternation greps silently return nothing — verify negative claims by reading the file."}
{"id":"lesson-stale-note","type":"lesson","reinforcements":1,"text":"Rename plans _completed only after every item is implemented and verified with fresh command output."}
