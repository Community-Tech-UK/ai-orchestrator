{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.ai.orchestrator",
  "productName": "AI Orchestrator",
  "npmRebuild": true,
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "!dist/out-tsc/**/*"
  ],
  "asarUnpack": [
    "node_modules/whatsapp-web.js/**/*",
    "node_modules/puppeteer-core/**/*"
  ],
  "extraResources": [
    {
      "from": "config",
      "to": "config",
      "filter": ["**/*"]
    },
    {
      "from": "docs",
      "to": "docs",
      "filter": ["BROWSER_AUTOMATION_SETUP.md", "runbooks/**/*"]
    },
    {
      "from": "src/main/cli/hooks",
      "to": "hooks",
      "filter": ["*.mjs"]
    },
    {
      "from": "dist/loop-control-cli-sea",
      "to": "loop-control-cli",
      "filter": ["aio-loop-control*"]
    },
    {
      "from": "resources/browser-extension",
      "to": "browser-extension",
      "filter": ["**/*"]
    }
  ],
  "mac": {
    "category": "public.app-category.developer-tools",
    "icon": "build/icon.icns",
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      }
    ],
    "darkModeSupport": true,
    "hardenedRuntime": true,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "notarize": false,
    "extendInfo": {
      "NSLocalNetworkUsageDescription": "AI Orchestrator uses your local network to discover and connect to worker nodes on other machines.",
      "NSMicrophoneUsageDescription": "AI Orchestrator uses the microphone only when you enable voice conversation for a session."
    },
    "extraResources": [
      {
        "from": "resources/rtk/darwin-${arch}/",
        "to": "rtk/darwin-${arch}/",
        "filter": ["rtk"]
      }
    ]
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Development",
    "extraResources": [
      {
        "from": "resources/rtk/linux-${arch}/",
        "to": "rtk/linux-${arch}/",
        "filter": ["rtk"]
      }
    ]
  },
  "win": {
    "target": [
      "nsis",
      "portable"
    ],
    "extraResources": [
      {
        "from": "resources/rtk/win32-${arch}/",
        "to": "rtk/win32-${arch}/",
        "filter": ["rtk.exe"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "afterPack": "scripts/set-electron-fuses.js"
}
