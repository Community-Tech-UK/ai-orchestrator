{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.ai.orchestrator",
  "productName": "Harness",
  "npmRebuild": false,
  "publish": [
    {
      "provider": "github",
      "owner": "Community-Tech-UK",
      "repo": "ai-orchestrator",
      "releaseType": "release"
    }
  ],
  "electronUpdaterCompatibility": ">=2.16",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": ["dist/**/*", "!dist/out-tsc/**/*"],
  "asarUnpack": [
    "node_modules/whatsapp-web.js/**/*",
    "node_modules/puppeteer-core/**/*"
  ],
  "extraResources": [
    {
      "from": "config",
      "to": "config",
      "filter": ["**/*"]
    },
    {
      "from": "docs",
      "to": "docs",
      "filter": ["BROWSER_AUTOMATION_SETUP.md", "runbooks/**/*"]
    },
    {
      "from": "src/main/cli/hooks",
      "to": "hooks",
      "filter": ["*.mjs"]
    },
    {
      "from": "dist/loop-control-cli-sea",
      "to": "loop-control-cli",
      "filter": ["aio-loop-control*"]
    },
    {
      "from": "dist/aio-mcp-cli-sea",
      "to": "aio-mcp-cli",
      "filter": ["aio-mcp*"]
    },
    {
      "from": "dist/worker-agent-sea",
      "to": "worker-agent-cli",
      "filter": ["worker-agent*", "aio-worker*", "worker-tools/**/*"]
    },
    {
      "from": "resources/browser-extension",
      "to": "browser-extension",
      "filter": ["**/*"]
    }
  ],
  "mac": {
    "category": "public.app-category.developer-tools",
    "icon": "build/icon.icns",
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64", "x64"]
      },
      {
        "target": "zip",
        "arch": ["arm64", "x64"]
      }
    ],
    "artifactName": "Harness-${version}-mac-${arch}.${ext}",
    "darkModeSupport": true,
    "hardenedRuntime": true,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "notarize": true,
    "extendInfo": {
      "NSLocalNetworkUsageDescription": "Harness uses your local network to discover and connect to worker nodes on other machines.",
      "NSMicrophoneUsageDescription": "Harness uses the microphone only when you enable voice conversation for a session."
    },
    "extraResources": [
      {
        "from": "dist/desktop-helper/",
        "to": "desktop-helper/",
        "filter": ["desktop-helper"]
      },
      {
        "from": "resources/rtk/darwin-${arch}/",
        "to": "rtk/darwin-${arch}/",
        "filter": ["rtk"]
      }
    ]
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64", "arm64"]
      }
    ],
    "artifactName": "Harness-${version}-linux-${arch}.${ext}",
    "category": "Development",
    "extraResources": [
      {
        "from": "resources/rtk/linux-${arch}/",
        "to": "rtk/linux-${arch}/",
        "filter": ["rtk"]
      }
    ]
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "artifactName": "Harness-${version}-win-${arch}.${ext}",
    "extraResources": [
      {
        "from": "resources/rtk/win32-${arch}/",
        "to": "rtk/win32-${arch}/",
        "filter": ["rtk.exe"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "afterPack": "scripts/set-electron-fuses.js"
}
