{
  "manifest_version": 3,
  "name": "AI Orchestrator Browser Gateway",
  "version": "0.1.0",
  "description": "Share the current Chrome tab with AI Orchestrator Browser Gateway.",
  "key": "",
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "scripting",
    "tabs"
  ],
  "action": {
    "default_title": "AI Orchestrator",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
