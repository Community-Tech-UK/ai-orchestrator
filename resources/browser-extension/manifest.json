{
  "manifest_version": 3,
  "name": "Harness Browser Gateway",
  "version": "0.2.1",
  "description": "Share the current Chrome tab with Harness Browser Gateway.",
  "key": "",
  "permissions": [
    "activeTab",
    "alarms",
    "debugger",
    "downloads",
    "nativeMessaging",
    "scripting",
    "storage",
    "tabGroups",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Harness",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
