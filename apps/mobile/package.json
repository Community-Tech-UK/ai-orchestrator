{
  "name": "harness-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "harness phone control app (Angular + Capacitor): connect to instances over Tailscale, read transcripts, send prompts, approve/deny, and get push alerts.",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "lint": "npx eslint \"src/**/*.{ts,html}\"",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "sync": "npm run build && npx cap sync ios && npm run ios:ensure-display-name && npm run ios:ensure-brand-assets && npm run ios:ensure-native-sources",
    "ios:ensure-display-name": "node scripts/ensure-ios-display-name.mjs",
    "ios:ensure-brand-assets": "node scripts/ensure-ios-brand-assets.mjs",
    "ios:ensure-native-sources": "node scripts/ensure-ios-native-sources.mjs",
    "ios": "npm run sync && npx cap open ios"
  },
  "dependencies": {
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor-mlkit/barcode-scanning": "^7.0.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/clipboard": "^7.0.4",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.5",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.0",
    "dompurify": "^3.4.10",
    "marked": "^18.0.5",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.13",
    "@capacitor/cli": "^7.0.0",
    "typescript": "~5.9.0"
  }
}
