{
  "name": "ai-orchestrator",
  "version": "0.1.0",
  "description": "Desktop application for managing multiple AI CLI instances",
  "main": "dist/main/index.js",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/check-node.js && npm run generate:ipc && npm run verify:ipc && npm run verify:exports",
    "prebuild": "node scripts/check-node.js && npm run generate:ipc && npm run verify:ipc && npm run verify:exports",
    "pretest": "node scripts/check-node.js && node scripts/ensure-test-native-modules.js && npm run verify:exports",
    "start": "npm run build:main && concurrently -k \"npm run watch:main\" \"npm run start:renderer -- --port 4567\" \"wait-on http://localhost:4567 && npm run electron:dev\"",
    "start:renderer": "ng serve",
    "dev": "npm run build:main && concurrently -k \"npm run watch:main\" \"npm run start:renderer -- --port 4567\" \"wait-on http://localhost:4567 && npm run electron:dev\"",
    "build": "npm run build:renderer && npm run build:main && npm run build:worker-agent",
    "build:renderer": "ng build --configuration production",
    "build:main": "tsc -p tsconfig.electron.json && node scripts/sync-dist.js && tsx build-preload.ts",
    "watch:main": "tsc -p tsconfig.electron.json --watch",
    "electron:dev": "electron .",
    "electron:build": "electron-builder",
    "test": "vitest run",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "bench": "vitest bench",
    "bench:indexing": "vitest bench src/main/indexing/benchmarks/indexing.bench.ts",
    "bench:search": "vitest bench src/main/indexing/benchmarks/search.bench.ts",
    "test:load": "vitest run src/main/indexing/__tests__/load/",
    "lint": "ng lint",
    "verify:ipc": "node scripts/verify-ipc-channels.js",
    "verify:exports": "node scripts/verify-package-exports.js",
    "generate:ipc": "node scripts/generate-preload-channels.js",
    "postinstall": "node scripts/rebuild-native-modules.js",
    "rebuild:native": "node scripts/rebuild-native-modules.js",
    "build:worker-agent": "tsx build-worker-agent.ts"
  },
  "keywords": [
    "ai",
    "ai-orchestrator",
    "claude",
    "gemini",
    "openai",
    "orchestrator",
    "electron",
    "angular"
  ],
  "author": "James",
  "license": "MIT",
  "overrides": {
    "undici": "^7.8.0",
    "picomatch": "^4.0.4",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@anthropic-ai/sdk": "^0.71.2",
    "@github/copilot-sdk": "^0.1.16",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "better-sqlite3": "^12.6.2",
    "bonjour-service": "^1.3.0",
    "chokidar": "^5.0.0",
    "diff": "^8.0.3",
    "discord.js": "^14.25.1",
    "dompurify": "^3.3.1",
    "echarts": "^6.0.0",
    "electron-store": "^11.0.2",
    "file-saver": "^2.0.5",
    "glob": "^13.0.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.1",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "marked": "^17.0.1",
    "ngx-echarts": "^21.0.0",
    "puppeteer-core": "^22.15.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "uuid": "^13.0.0",
    "whatsapp-web.js": "^1.34.6",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.0",
    "@angular/cli": "^21.1.0",
    "@angular/compiler-cli": "^21.2.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/file-saver": "^2.0.7",
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "angular-eslint": "21.3.1",
    "concurrently": "^9.0.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "jsdom": "^27.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "8.47.0",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.0",
    "zone.js": "^0.16.0"
  }
}
