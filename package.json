{
  "name": "harness",
  "version": "0.1.0",
  "description": "Harness — desktop application for managing multiple AI CLI instances",
  "main": "dist/main/index.js",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/check-node.js && node scripts/verify-native-abi.js && npm run generate:aliases && npm run generate:ipc && npm run verify:ipc && npm run verify:exports && npm run check:contracts",
    "prebuild": "node scripts/check-node.js && node scripts/verify-native-abi.js && npm run generate:aliases && npm run generate:ipc && npm run verify:ipc && npm run verify:exports && npm run check:contracts",
    "start": "npm run build:main && npm run build:aio-mcp-dist && concurrently -k \"npm run watch:main\" \"npm run start:renderer -- --port 4567\" \"wait-on http://localhost:4567 && npm run electron:dev\"",
    "start:renderer": "ng serve",
    "dev": "npm run build:main && npm run build:aio-mcp-dist && concurrently -k \"npm run watch:main\" \"npm run start:renderer -- --port 4567\" \"wait-on http://localhost:4567 && npm run electron:dev\"",
    "dev:cost-attribution": "AIO_COST_ATTRIBUTION=1 npm run dev",
    "build": "npm run build:renderer && npm run build:main && npm run build:worker-dist && npm run build:loop-control-dist && npm run build:aio-mcp-dist",
    "build:renderer": "ng build --configuration production",
    "build:main": "tsc -p tsconfig.electron.json && node scripts/sync-dist.js && tsx build-preload.ts",
    "watch:main": "tsc -p tsconfig.electron.json --watch",
    "electron:dev": "electron .",
    "preelectron:build": "npm run build:worker-dist && npm run build:loop-control-dist && npm run build:aio-mcp-dist",
    "electron:build": "node scripts/fetch-rtk-binaries.js && electron-builder",
    "fetch:rtk": "node scripts/fetch-rtk-binaries.js",
    "localbuild": "npm run rebuild:native && npm run build && node scripts/localbuild.js",
    "test": "node scripts/run-tests-quiet.js",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:staged": "node scripts/test-staged.js",
    "test:quiet": "node scripts/run-tests-quiet.js",
    "test:coverage": "vitest --coverage",
    "bench": "vitest bench",
    "bench:indexing": "vitest bench src/main/indexing/benchmarks/indexing.bench.ts",
    "bench:search": "vitest bench src/main/indexing/benchmarks/search.bench.ts",
    "test:load": "vitest run src/main/indexing/__tests__/load/",
    "lint": "ng lint",
    "lint:colors": "node scripts/lint-colors.js",
    "lint:fast": "oxlint --config .oxlintrc.json src/main src/shared src/preload packages/contracts/src packages/sdk/src",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.electron.json",
    "typecheck:fast": "tsgo --noEmit -p tsconfig.electron.json",
    "typecheck:spec": "tsc --noEmit -p tsconfig.spec.json",
    "verify": "npm run lint && npm run lint:fast && npm run typecheck && npm run typecheck:spec && npm run check:ts-max-loc && npm run check:dead && npm run verify:ipc && npm run verify:ipc-usage && npm run verify:exports && npm run check:contracts && npm run test && npm run verify:architecture && npm run rebuild:native && npm run smoke:electron",
    "verify:ipc": "node scripts/verify-ipc-channels.js",
    "verify:ipc-usage": "node scripts/verify-ipc-usage.js",
    "verify:exports": "node scripts/verify-package-exports.js",
    "check:contracts": "tsx scripts/check-contracts-aliases.ts",
    "check:ts-max-loc": "tsx scripts/check-ts-max-loc.ts",
    "check:dead": "node scripts/check-dead-exports.js",
    "check:provider-parity": "node scripts/check-provider-parity.js",
    "audit:claude-cost": "node scripts/claude-cost-audit-report.mjs",
    "verify:architecture": "node scripts/check-import-boundaries.js && node scripts/generate-architecture-inventory.js --check",
    "verify:boundaries": "node scripts/check-import-boundaries.js",
    "generate:architecture": "node scripts/generate-architecture-inventory.js --write",
    "smoke:electron": "node scripts/electron-smoke-check.js",
    "smoke:provider-events": "tsx scripts/provider-event-stress-smoke.ts",
    "soak:long-loop": "tsx scripts/soak-long-loop.ts",
    "generate:aliases": "node scripts/generate-register-aliases.js",
    "generate:ipc": "node scripts/generate-preload-channels.js",
    "generate:cursor-models": "tsx scripts/generate-cursor-models.ts",
    "sync:model-catalog": "tsx scripts/sync-model-catalog.ts",
    "install:git-hooks": "node scripts/install-git-hooks.js",
    "install:global-gitignore": "node scripts/install-global-gitignore.js",
    "postinstall": "node scripts/rebuild-native-modules.js && node scripts/install-git-hooks.js && node scripts/install-global-gitignore.js",
    "rebuild:native": "node scripts/rebuild-native-modules.js",
    "build:worker-agent": "tsx build-worker-agent.ts",
    "build:worker-sea": "tsx build-worker-agent-sea.ts",
    "build:worker-dist": "npm run build:worker-agent && npm run build:worker-sea",
    "build:loop-control-cli": "tsx build-loop-control-cli.ts",
    "build:loop-control-sea": "tsx build-loop-control-cli-sea.ts",
    "build:loop-control-dist": "npm run build:loop-control-cli && npm run build:loop-control-sea",
    "build:aio-mcp-cli": "tsx build-aio-mcp-cli.ts",
    "build:aio-mcp-sea": "tsx build-aio-mcp-cli-sea.ts",
    "build:aio-mcp-dist": "npm run build:aio-mcp-cli && npm run build:aio-mcp-sea",
    "download:winsw": "node scripts/download-winsw.js",
    "review": "tsx src/main/cli-entrypoints/review-command.ts",
    "visual:qa": "node scripts/visual-qa-screenshots.mjs --all"
  },
  "keywords": [
    "ai",
    "harness",
    "claude",
    "gemini",
    "openai",
    "orchestrator",
    "electron",
    "angular"
  ],
  "author": "James",
  "license": "MIT",
  "overrides": {
    "undici": "^7.8.0",
    "picomatch": "^4.0.4",
    "vite": "^7.3.2",
    "protobufjs": "^8.6.4"
  },
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@anthropic-ai/sdk": "^0.71.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "bonjour-service": "^1.3.0",
    "chokidar": "^5.0.0",
    "croner": "^10.0.1",
    "diff": "^8.0.3",
    "discord.js": "^14.25.1",
    "dompurify": "^3.4.10",
    "echarts": "^6.1.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "file-saver": "^2.0.5",
    "glob": "^13.0.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "ignore": "^7.0.5",
    "isomorphic-dompurify": "^3.9.0",
    "js-yaml": "^4.2.0",
    "jsonrepair": "^3.14.1",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "marked": "^17.0.1",
    "ngx-echarts": "^21.0.0",
    "node-pty": "^1.1.0",
    "partial-json": "^0.1.7",
    "puppeteer-core": "^22.15.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "safe-regex2": "^5.1.1",
    "tldts": "^7.0.5",
    "tslib": "^2.6.0",
    "uuid": "^13.0.0",
    "whatsapp-web.js": "^1.34.6",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.15",
    "@angular/cli": "^21.2.15",
    "@angular/compiler-cli": "^21.2.17",
    "@axe-core/puppeteer": "^4.11.0",
    "@electron/fuses": "^2.1.1",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build9",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/file-saver": "^2.0.7",
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "^7.0.0-dev.20250327.1",
    "angular-eslint": "21.4.0",
    "concurrently": "^9.0.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "jsdom": "^27.4.0",
    "oxlint": "^1.0.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.21.0",
    "turbo": "^2.5.4",
    "typescript": "~5.9.0",
    "typescript-eslint": "8.47.0",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.0",
    "zone.js": "^0.16.0"
  }
}
